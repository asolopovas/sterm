{
  "version": "2.0.0",
  "inputs": [
    {
      "id": "hostArgs",
      "type": "promptString",
      "description": "Arguments for the standalone host",
      "default": ""
    }
  ],
  "tasks": [
    {
      "label": "just: dev",
      "type": "process",
      "command": "just",
      "args": ["dev"],
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "just: check",
      "type": "process",
      "command": "just",
      "args": ["check"],
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": ["$tsc", "$rustc"]
    },
    {
      "label": "just: verify",
      "type": "process",
      "command": "just",
      "args": ["verify"],
      "group": "test",
      "problemMatcher": ["$tsc", "$rustc"]
    },
    {
      "label": "just: build-debug",
      "type": "process",
      "command": "just",
      "args": ["build-debug"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$tsc", "$rustc"]
    },
    {
      "label": "just: build",
      "type": "process",
      "command": "just",
      "args": ["build"],
      "group": "build",
      "problemMatcher": ["$tsc", "$rustc"]
    },
    {
      "label": "just: host",
      "type": "process",
      "command": "just",
      "args": ["host", "${input:hostArgs}"],
      "problemMatcher": ["$rustc"],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "just: android-dev",
      "type": "process",
      "command": "just",
      "args": ["android-dev"],
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "just: install",
      "type": "process",
      "command": "just",
      "args": ["install"],
      "problemMatcher": ["$tsc", "$rustc"],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "just: doctor",
      "type": "process",
      "command": "just",
      "args": ["doctor"],
      "problemMatcher": []
    },
    {
      "label": "just: clean",
      "type": "process",
      "command": "just",
      "args": ["clean"],
      "problemMatcher": []
    }
  ]
}
